bot:
  command: "/bot run"
  plan_command: "/bot plan"
  help_command: "/bot help"
  status_command: "/bot status"
  mention: "@your-bot"
  provider: "codex"
  mode: "codex"
  branch_prefix: "bot"
  branch_name_template: "{branch_prefix}/issue-{issue_number}{comment_suffix}-{slug}"
  pr_title_template: "[bot] Issue #{issue_number}: {issue_title}"
  codex_commit_message_template: "feat(issue-{issue_number}): {issue_title}"
  test_commit_message_template: "chore(issue-{issue_number}): marker"
  output_dir: "bot-output"
  check_commands:
    - "python -m compileall -q app tests"
    - "python -m unittest discover -s tests"
  context_paths:
    - ".issue-to-pr-bot.yml"
    - "AGENTS.md"
    - "CONTRIBUTING.md"
    - "README.md"
    - ".github/pull_request_template.md"
  external_context_paths:
    - "product"
  required_context_paths:
    - "README.md"
    - "external:product/domain.md"
  secret_env_keys:
    - "DB_URL"
  required_secret_env:
    - "DB_URL"
  protected_paths:
    - ".github/workflows/**"
    - ".env"
    - ".env.*"
    - "*.pem"
    - "*.key"
    - "*.p12"
    - "*.pfx"

