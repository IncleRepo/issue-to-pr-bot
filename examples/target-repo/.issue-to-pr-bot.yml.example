bot:
  # Codex? workspace ?? ?? ??? ???? ?????.
  output_dir: "bot-output"

  # Codex? ?? ?? ?? ??? ?? ??/?? ?????.
  context_paths:
    - ".issue-to-pr-bot.yml"
    - "AGENTS.md"
    - "README.md"

  # ?? ???? ????(EXTERNAL_CONTEXT_DIR_ENV)?? ?? ?????.
  external_context_paths:
    - "product"

  # ??? ??? ???? ?? ?? ?? ?????.
  required_context_paths:
    - "docs/domain.md"
    - "external:product/api.md"

  # ?? ????? Codex? ??? secret env ?? ?????.
  secret_env_keys:
    - "DB_URL"
    - "OPENAI_API_KEY"

  # ??? ??? ????? ?? secret env ?? ?????.
  required_secret_env:
    - "DB_URL"

  # wrapper? ?? ??? ??? ?????.
  check_commands:
    - "python -m compileall -q app tests"
    - "python -m unittest discover -s tests"

  # ?? ?? ??? ??? ?????.
  protected_paths:
    - "secrets/**"

  # ?? ?? ?? ?? ????? Git sync ??? ??? ? ?????.
  base_branch: "main"
  git_sync_phase: "before_merge"
  git_sync_action: "merge"
  git_sync_base_branch: "main"
  git_sync_require_conflict_free: true

