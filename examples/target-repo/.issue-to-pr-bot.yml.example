bot:
  # Codex가 workspace 안에 둘 산출물 디렉터리 이름입니다.
  output_dir: "bot-output"

  # Codex가 항상 함께 읽을 저장소 내부 문서/설정 경로입니다.
  context_paths:
    - ".issue-to-pr-bot.yml"
    - "AGENTS.md"
    - "README.md"

  # 외부 컨텍스트 디렉터리(EXTERNAL_CONTEXT_DIR_ENV)에서 읽을 경로입니다.
  external_context_paths:
    - "product"

  # 없으면 작업을 시작하지 않을 필수 문서 경로입니다.
  required_context_paths:
    - "docs/domain.md"
    - "external:product/api.md"

  # 사용 가능하다고 Codex에 알려줄 secret env 이름 목록입니다.
  secret_env_keys:
    - "DB_URL"
    - "OPENAI_API_KEY"

  # 없으면 작업을 실패시키는 필수 secret env 이름 목록입니다.
  required_secret_env:
    - "DB_URL"

  # wrapper가 최종 검증에 사용할 명령입니다.
  check_commands:
    - "python -m compileall -q app tests"
    - "python -m unittest discover -s tests"

  # 기본 보호 경로에 추가로 합쳐집니다.
  protected_paths:
    - "secrets/**"

  # 문서 자동 추론 대신 명시적으로 Git sync 규칙을 고정할 때 사용합니다.
  base_branch: "main"
  git_sync_phase: "before_merge"
  git_sync_action: "merge"
  git_sync_base_branch: "main"
  git_sync_require_conflict_free: true

  # 고급 키는 대부분 선택 사항입니다.
  # 지금 구조에서는 Codex가 문서와 요청을 더 주도적으로 해석하므로 꼭 적지 않아도 됩니다.
