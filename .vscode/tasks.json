{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run app",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "app.main"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Ruff check",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\ruff.exe",
      "args": ["check", "."],
      "problemMatcher": []
    },
    {
      "label": "Ruff format",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\ruff.exe",
      "args": ["format", "."],
      "problemMatcher": []
    }
  ]
}
