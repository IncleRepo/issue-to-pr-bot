const textEncoder = new TextEncoder();

export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);

    if (request.method === "GET" && url.pathname === "/health") {
      return json({ ok: true, service: "issue-to-pr-bot-control-plane" });
    }

    if (request.method === "POST" && url.pathname === "/github/webhook") {
      return handleGithubWebhook(request, env, ctx);
    }

    if (request.method === "GET" && url.pathname === "/api/tasks/claim") {
      return handleClaimTask(request, env);
    }

    if (request.method === "GET" && url.pathname === "/api/agent/config") {
      return handleAgentConfig(request, env);
    }

    if (request.method === "POST" && url.pathname.startsWith("/api/tasks/") && url.pathname.endsWith("/complete")) {
      return handleCompleteTask(request, env, url.pathname.split("/")[3]);
    }

    return json({ error: "not_found" }, 404);
  },
};

async function handleGithubWebhook(request, env, ctx) {
  const eventName = request.headers.get("X-GitHub-Event") || "";
  const deliveryId = request.headers.get("X-GitHub-Delivery") || crypto.randomUUID();
  const rawBody = await request.text();

  if (!(await verifyWebhookSignature(request, rawBody, env))) {
    return json({ error: "invalid_signature" }, 401);
  }

  let payload;
  try {
    payload = JSON.parse(rawBody);
  } catch {
    return json({ error: "invalid_json" }, 400);
  }

  if (!shouldEnqueue(eventName, payload, env)) {
    return json({ accepted: false, reason: "ignored_event" });
  }

  const duplicateKeys = buildDuplicateKeys(eventName, deliveryId, payload);
  for (const key of duplicateKeys) {
    if (await env.TASK_QUEUE.get(key)) {
      return json({ accepted: false, reason: "duplicate_event" });
    }
  }
  for (const key of duplicateKeys) {
    await env.TASK_QUEUE.put(
      key,
      JSON.stringify({ createdAt: new Date().toISOString() }),
      { expirationTtl: 7 * 24 * 60 * 60 },
    );
  }

  const installationId = payload?.installation?.id;
  if (!installationId) {
    return json({ accepted: false, reason: "missing_installation" }, 400);
  }

  const taskId = crypto.randomUUID();
  const task = {
    id: taskId,
    status: "pending",
    eventName,
    deliveryId,
    repository: payload?.repository?.full_name || "unknown/unknown",
    defaultBranch: payload?.repository?.default_branch || "main",
    installationId,
    createdAt: new Date().toISOString(),
    payload,
  };

  await env.TASK_QUEUE.put(taskKey(taskId), JSON.stringify(task));
  if (ctx && shouldReactWithEyes(eventName, payload, env)) {
    ctx.waitUntil(addRecognitionReaction(task.repository, installationId, eventName, payload, env));
  }
  return json({ accepted: true, taskId });
}

async function handleClaimTask(request, env) {
  if (!isAuthorizedAgent(request, env)) {
    return json({ error: "unauthorized" }, 401);
  }

  const url = new URL(request.url);
  const repositories = (url.searchParams.get("repositories") || "")
    .split(",")
    .map((value) => value.trim())
    .filter(Boolean);
  const agentId = url.searchParams.get("agent_id") || "unknown-agent";

  const listed = await env.TASK_QUEUE.list({ prefix: "task:" });
  for (const entry of listed.keys) {
    const rawTask = await env.TASK_QUEUE.get(entry.name);
    if (!rawTask) {
      continue;
    }
    const task = JSON.parse(rawTask);
    if (task.status !== "pending") {
      continue;
    }
    if (repositories.length && !repositories.includes(task.repository)) {
      continue;
    }

    task.status = "claimed";
    task.claimedAt = new Date().toISOString();
    task.agentId = agentId;
    await env.TASK_QUEUE.put(entry.name, JSON.stringify(task));

    const githubToken = await mintInstallationToken(task.installationId, env);
    return json({
      task: {
        id: task.id,
        eventName: task.eventName,
        deliveryId: task.deliveryId,
        repository: task.repository,
        defaultBranch: task.defaultBranch,
        payload: task.payload,
        githubToken,
      },
    });
  }

  return json({ task: null });
}

async function handleAgentConfig(request, env) {
  if (!isAuthorizedAgent(request, env)) {
    return json({ error: "unauthorized" }, 401);
  }

  return json({
    repositories: parseManagedRepositories(env),
    pollIntervalSeconds: parseManagedPollInterval(env),
    maxConcurrency: parseManagedMaxConcurrency(env),
  });
}

async function handleCompleteTask(request, env, taskId) {
  if (!isAuthorizedAgent(request, env)) {
    return json({ error: "unauthorized" }, 401);
  }

  const rawTask = await env.TASK_QUEUE.get(taskKey(taskId));
  if (!rawTask) {
    return json({ error: "not_found" }, 404);
  }

  const update = await request.json();
  const task = JSON.parse(rawTask);
  task.status = update.status || "completed";
  task.completedAt = new Date().toISOString();
  task.result = {
    summary: update.summary || "",
    detail: update.detail || "",
  };
  await env.TASK_QUEUE.put(taskKey(taskId), JSON.stringify(task));
  return json({ ok: true });
}

function shouldEnqueue(eventName, payload, env) {
  const mention = (env.BOT_MENTION || "").trim();
  const action = String(payload?.action || "").toLowerCase();
  const association = payload?.comment?.author_association || payload?.review?.author_association || "";
  const allowedAssociation = ["OWNER", "MEMBER", "COLLABORATOR"].includes(association);
  if (!mention) {
    return false;
  }

  if (eventName === "issue_comment") {
    return action === "created" && allowedAssociation && (payload?.comment?.body || "").includes(mention);
  }
  if (eventName === "pull_request_review_comment") {
    return action === "created" && allowedAssociation && (payload?.comment?.body || "").includes(mention);
  }
  if (eventName === "pull_request_review") {
    const body = payload?.review?.body || "";
    const state = (payload?.review?.state || "").toLowerCase();
    return action === "submitted" && allowedAssociation && (body.includes(mention) || state === "approved");
  }
  if (eventName === "check_run") {
    const conclusion = (payload?.check_run?.conclusion || "").toLowerCase();
    const pullRequests = payload?.check_run?.pull_requests || [];
    return action === "completed" && conclusion === "success" && pullRequests.length > 0;
  }
  if (eventName === "check_suite") {
    const conclusion = (payload?.check_suite?.conclusion || "").toLowerCase();
    const pullRequests = payload?.check_suite?.pull_requests || [];
    return action === "completed" && conclusion === "success" && pullRequests.length > 0;
  }
  if (eventName === "status") {
    const state = (payload?.state || "").toLowerCase();
    const branches = payload?.branches || [];
    return state === "success" && branches.length > 0;
  }
  return false;
}

function buildDuplicateKeys(eventName, deliveryId, payload) {
  const repository = payload?.repository?.full_name || "unknown/unknown";
  const action = String(payload?.action || "").toLowerCase() || "unknown";
  const keys = [];

  if (deliveryId) {
    keys.push(`dedupe:delivery:${deliveryId}`);
  }

  if (eventName === "issue_comment" || eventName === "pull_request_review_comment") {
    const commentId = payload?.comment?.id;
    if (commentId) {
      keys.push(`dedupe:${eventName}:${repository}:comment:${commentId}:action:${action}`);
    }
  }

  if (eventName === "pull_request_review") {
    const reviewId = payload?.review?.id;
    if (reviewId) {
      keys.push(`dedupe:${eventName}:${repository}:review:${reviewId}:action:${action}`);
    }
  }

  if (eventName === "check_run") {
    const checkRunId = payload?.check_run?.id;
    const conclusion = (payload?.check_run?.conclusion || "").toLowerCase() || "unknown";
    if (checkRunId) {
      keys.push(`dedupe:${eventName}:${repository}:check:${checkRunId}:action:${action}:conclusion:${conclusion}`);
    }
  }

  if (eventName === "check_suite") {
    const checkSuiteId = payload?.check_suite?.id;
    const conclusion = (payload?.check_suite?.conclusion || "").toLowerCase() || "unknown";
    if (checkSuiteId) {
      keys.push(`dedupe:${eventName}:${repository}:check:${checkSuiteId}:action:${action}:conclusion:${conclusion}`);
    }
  }

  if (eventName === "status") {
    const sha = payload?.sha || "unknown";
    const context = payload?.context || "unknown";
    const state = (payload?.state || "").toLowerCase() || "unknown";
    keys.push(`dedupe:${eventName}:${repository}:sha:${sha}:context:${context}:state:${state}`);
  }

  return [...new Set(keys)];
}

function shouldReactWithEyes(eventName, payload, env) {
  if (!shouldEnqueue(eventName, payload, env)) {
    return false;
  }
  return eventName === "issue_comment" || eventName === "pull_request_review_comment";
}

function parseManagedRepositories(env) {
  return String(env.AGENT_REPOSITORIES || "")
    .split(",")
    .map((value) => value.trim())
    .filter(Boolean);
}

function parseManagedPollInterval(env) {
  const rawValue = Number.parseInt(String(env.AGENT_POLL_INTERVAL_SECONDS || "").trim(), 10);
  if (!Number.isFinite(rawValue) || rawValue <= 0) {
    return 10;
  }
  return rawValue;
}

function parseManagedMaxConcurrency(env) {
  const rawValue = Number.parseInt(String(env.AGENT_MAX_CONCURRENCY || "").trim(), 10);
  if (!Number.isFinite(rawValue) || rawValue <= 0) {
    return null;
  }
  return rawValue;
}

async function addRecognitionReaction(repository, installationId, eventName, payload, env) {
  try {
    const target = reactionTargetForEvent(repository, eventName, payload);
    if (!target) {
      return;
    }
    const githubToken = await mintInstallationToken(installationId, env);
    const response = await fetch(`https://api.github.com${target.path}`, {
      method: "POST",
      headers: {
        Accept: "application/vnd.github+json",
        Authorization: `Bearer ${githubToken}`,
        "Content-Type": "application/json",
        "User-Agent": "issue-to-pr-bot-control-plane",
        "X-GitHub-Api-Version": "2022-11-28",
      },
      body: JSON.stringify({ content: "eyes" }),
    });
    if (!response.ok && response.status !== 200) {
      const body = await response.text();
      console.log(`Failed to add recognition reaction (${response.status}): ${body}`);
    }
  } catch (error) {
    console.log(`Failed to add recognition reaction: ${String(error)}`);
  }
}

function reactionTargetForEvent(repository, eventName, payload) {
  const commentId = payload?.comment?.id;
  if (!repository || !commentId) {
    return null;
  }
  if (eventName === "issue_comment") {
    return {
      path: `/repos/${repository}/issues/comments/${commentId}/reactions`,
    };
  }
  if (eventName === "pull_request_review_comment") {
    return {
      path: `/repos/${repository}/pulls/comments/${commentId}/reactions`,
    };
  }
  return null;
}

async function verifyWebhookSignature(request, rawBody, env) {
  const secret = env.GITHUB_WEBHOOK_SECRET;
  if (!secret) {
    return true;
  }

  const signature = request.headers.get("X-Hub-Signature-256");
  if (!signature || !signature.startsWith("sha256=")) {
    return false;
  }

  const key = await crypto.subtle.importKey(
    "raw",
    textEncoder.encode(secret),
    { name: "HMAC", hash: "SHA-256" },
    false,
    ["sign"],
  );
  const digest = await crypto.subtle.sign("HMAC", key, textEncoder.encode(rawBody));
  const expected = `sha256=${toHex(digest)}`;
  return timingSafeEqual(expected, signature);
}

function isAuthorizedAgent(request, env) {
  const auth = request.headers.get("Authorization") || "";
  const headerToken = auth.startsWith("Bearer ") ? auth.slice("Bearer ".length) : "";
  const queryToken = new URL(request.url).searchParams.get("agent_token") || "";
  const token = (headerToken || queryToken).trim();
  const expected = String(env.CONTROL_PLANE_AGENT_TOKEN || "").trim();
  return !!token && !!expected && token === expected;
}

async function mintInstallationToken(installationId, env) {
  const appId = env.GITHUB_APP_ID;
  const privateKeyPem = env.GITHUB_APP_PRIVATE_KEY;
  if (!appId || !privateKeyPem) {
    throw new Error("Missing GitHub App credentials in Worker secrets.");
  }

  const jwt = await buildAppJwt(appId, privateKeyPem);
  const response = await fetch(`https://api.github.com/app/installations/${installationId}/access_tokens`, {
    method: "POST",
    headers: {
      Accept: "application/vnd.github+json",
      Authorization: `Bearer ${jwt}`,
      "User-Agent": "issue-to-pr-bot-control-plane",
      "X-GitHub-Api-Version": "2022-11-28",
    },
  });

  if (!response.ok) {
    const body = await response.text();
    throw new Error(`Failed to mint installation token: ${response.status} ${body}`);
  }

  const data = await response.json();
  return data.token;
}

async function buildAppJwt(appId, privateKeyPem) {
  const now = Math.floor(Date.now() / 1000);
  const issuer = Number(appId);
  if (!Number.isInteger(issuer) || issuer <= 0) {
    throw new Error("GITHUB_APP_ID must be a positive integer.");
  }
  const header = { alg: "RS256", typ: "JWT" };
  const payload = {
    iat: now - 60,
    exp: now + 540,
    iss: issuer,
  };

  const encodedHeader = base64Url(JSON.stringify(header));
  const encodedPayload = base64Url(JSON.stringify(payload));
  const signingInput = `${encodedHeader}.${encodedPayload}`;

  const key = await importPrivateKey(privateKeyPem);
  const signature = await crypto.subtle.sign(
    { name: "RSASSA-PKCS1-v1_5" },
    key,
    textEncoder.encode(signingInput),
  );
  return `${signingInput}.${base64Url(signature)}`;
}

async function importPrivateKey(pem) {
  let format = "pkcs8";
  let clean = pem;
  if (pem.includes("-----BEGIN RSA PRIVATE KEY-----")) {
    format = "pkcs1";
    clean = clean
      .replace(/-----BEGIN RSA PRIVATE KEY-----/g, "")
      .replace(/-----END RSA PRIVATE KEY-----/g, "");
  } else {
    clean = clean
      .replace(/-----BEGIN PRIVATE KEY-----/g, "")
      .replace(/-----END PRIVATE KEY-----/g, "");
  }
  clean = clean.replace(/\s+/g, "");
  let der = Uint8Array.from(atob(clean), (c) => c.charCodeAt(0));
  if (format === "pkcs1") {
    der = wrapPkcs1InPkcs8(der);
  }
  return crypto.subtle.importKey(
    "pkcs8",
    der.buffer,
    { name: "RSASSA-PKCS1-v1_5", hash: "SHA-256" },
    false,
    ["sign"],
  );
}

function wrapPkcs1InPkcs8(pkcs1Bytes) {
  const version = Uint8Array.from([0x02, 0x01, 0x00]);
  const algorithmIdentifier = Uint8Array.from([
    0x30, 0x0d,
    0x06, 0x09,
    0x2a, 0x86, 0x48, 0x86, 0xf7, 0x0d, 0x01, 0x01, 0x01,
    0x05, 0x00,
  ]);
  const privateKey = encodeDerElement(0x04, pkcs1Bytes);
  return encodeDerElement(0x30, concatBytes(version, algorithmIdentifier, privateKey));
}

function encodeDerElement(tag, value) {
  return concatBytes(Uint8Array.from([tag]), encodeDerLength(value.length), value);
}

function encodeDerLength(length) {
  if (length < 0x80) {
    return Uint8Array.from([length]);
  }
  const bytes = [];
  let remaining = length;
  while (remaining > 0) {
    bytes.unshift(remaining & 0xff);
    remaining >>= 8;
  }
  return Uint8Array.from([0x80 | bytes.length, ...bytes]);
}

function concatBytes(...parts) {
  const total = parts.reduce((sum, part) => sum + part.length, 0);
  const result = new Uint8Array(total);
  let offset = 0;
  for (const part of parts) {
    result.set(part, offset);
    offset += part.length;
  }
  return result;
}

function taskKey(taskId) {
  return `task:${taskId}`;
}

function json(value, status = 200) {
  return new Response(JSON.stringify(value), {
    status,
    headers: {
      "content-type": "application/json; charset=utf-8",
    },
  });
}

function base64Url(value) {
  const bytes = typeof value === "string" ? textEncoder.encode(value) : new Uint8Array(value);
  let binary = "";
  bytes.forEach((byte) => {
    binary += String.fromCharCode(byte);
  });
  return btoa(binary).replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/g, "");
}

function toHex(buffer) {
  return Array.from(new Uint8Array(buffer))
    .map((byte) => byte.toString(16).padStart(2, "0"))
    .join("");
}

function timingSafeEqual(left, right) {
  if (left.length !== right.length) {
    return false;
  }
  let result = 0;
  for (let index = 0; index < left.length; index += 1) {
    result |= left.charCodeAt(index) ^ right.charCodeAt(index);
  }
  return result === 0;
}
